  "enabled_providers": ["anthropic", "litellm", "google","ollama"],
  // "experimental": {
  //   "quotaToast": {
  //     "enabledProviders": ["google-antigravity"]
  //   }
  // },
  "instructions": [
    "AGENTS.md",
    "CLAUDE.md"
  ],
  "mcp": {
    "chrome": {
      "type": "local",
      "command": [
        "env",
        "USE_PROXY=true",
        "PROXY_URL=http://localhost:1234",
        "HTTP_PROXY=http://localhost:1234",
        "HTTPS_PROXY=http://localhost:1234",
        "MODE=stdio",
        "npm_config_registry=https://registry.npmjs.org",
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--viewport=1024x768"
      ]
    },
    "context7": {
      "type": "local",
      "command": ["/home/me/.nvm/versions/node/v22.17.0/bin/context7-mcp"]
    },
    "excel": {
      "type": "local",
      "command": [
        "/home/me/excel-mcp-server/.venv/bin/excel-mcp-server",
        "stdio"
      ]
    },
    "filesystem": {
      "type": "local",
      "command": [
        "/home/me/mcp-filesystem/.venv/bin/python",
        "/home/me/mcp-filesystem/run_server.py",
        "/home/me"
      ]
    },
    "git": {
      "type": "local",
      "command": ["/home/me/mcp-git/.venv/bin/mcp-server-git"]
    },
    "websearch": {
      "type": "local",
      "command": [
        "env",
        "USE_PROXY=true",
        "PROXY_URL=http://localhost:1234",
        "HTTP_PROXY=http://localhost:1234",
        "HTTPS_PROXY=http://localhost:1234",
        "MODE=stdio",
        "npm_config_registry=https://registry.npmjs.org",
        "npx",
        "-y",
        "open-websearch"
      ]
    }
  },

  "model": "antigravity-gemini-3.1-pro",
  // "model": "google/gemini-3-pro-preview",
  //  "model": "anthropic/claude-sonnet-4-6",
  //  "model":"github_copilot/claude-sonnet-4.5",
  "small_model": "litellm/gpt-5-mini",
  "permission": {
    // Only deny non-standard tools
    "chrome_*": "deny",
    "context7_*": "deny",
    "filesystem_*": "deny",
    "git_*": "deny",
    "google_search": "deny", // Seems to be broken
    "pty_*": "deny",
    "websearch_*": "deny"
  },
  "plugin": [
    "@plannotator/opencode",
    "opencode-antigravity-auth@latest",
    //    "opencode-antigravity-quota@latest",
    "opencode-pty"
  ],
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "GitHub Copilot (GHE)",
      "options": {
        "baseURL": "http://127.0.0.1:4000/v1",
        "apiKey": "sk-1234"
      },
      "models": {
        "claude-haiku-4.5": {
          "id": "github_copilot/claude-haiku-4.5",
          "name": "Claude Haiku 4.5 (GHE)",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 200000,
            "output": 200000
          }
        },
        "claude-sonnet-4.5": {
          "id": "github_copilot/claude-sonnet-4.5",
          "name": "Claude Sonnet 4.5 (GHE)",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 200000,
            "output": 200000
          }
        },
        "claude-opus-4.5": {
          "id": "github_copilot/claude-opus-4.5",
          "name": "Claude Opus 4.5 (GHE)",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 200000,
            "output": 200000
          }
        },
        "gpt-5-mini": {
          "id": "github_copilot/gpt-5-mini",
          "name": "GPT 5 Mini (GHE)",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 128000,
            "output": 128000
          }
        },
        "gpt-5.2": {
          "id": "github_copilot/gpt-5.2",
          "name": "GPT 5.2 (GHE)",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 400000,
            "output": 400000
          }
        },
        "gpt-5.2-codex": {
          "id": "github_copilot/gpt-5.2-codex",
          "name": "GPT 5.2 Codex (GHE)",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 400000,
            "output": 400000
          }
        },
        "gemini-2.5-pro": {
          "id": "github_copilot/gemini-2.5-pro",
          "name": "Gemini 2.5 Pro (GHE)",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 1000000
          }
        },
        "gemini-3-flash-preview": {
          "name": "Gemini 3 Flash Preview (Gemini CLI)",
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          }
        },
        "gemini-3-pro-preview": {
          "name": "Gemini 3 Pro Preview (Gemini CLI)",
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    },
    "google": {
      "models": {
        "antigravity-gemini-3-pro": {
          "name": "Gemini 3 Pro (Antigravity)",
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
