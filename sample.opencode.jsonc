{
  "$schema": "https://opencode.ai/config.json",
  "agent": {},
  "enabled_providers": [
    "anthropic",
    "litellm",
    "google",
    "ollama",
    "openai"
  ],
  // "experimental": {
  //   "quotaToast": {
  //     "enabledProviders": ["google-antigravity"]
  //   }
  // },
  "instructions": [
    "AGENTS.md",
    "CLAUDE.md"
  ],
  "mcp": {
    "chrome": {
      "type": "local",
      "command": [
        "env",
        "USE_PROXY=true",
        "PROXY_URL=http://localhost:1234",
        "HTTP_PROXY=http://localhost:1234",
        "HTTPS_PROXY=http://localhost:1234",
        "MODE=stdio",
        "npm_config_registry=https://registry.npmjs.org",
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--viewport=1024x768"
      ]
    },
    "context7": {
      "type": "local",
      "command": [
        "/home/me/.nvm/versions/node/v22.17.0/bin/context7-mcp"
      ]
    },
    "excel": {
      "type": "local",
      "command": [
        "/home/me/excel-mcp-server/.venv/bin/excel-mcp-server",
        "stdio"
      ]
    },
    "filesystem": {
      "type": "local",
      "command": [
        "/home/me/mcp-filesystem/.venv/bin/python",
        "/home/me/mcp-filesystem/run_server.py",
        "/home/me"
      ]
    },
    "git": {
      "type": "local",
      "command": [
        "/home/me/mcp-git/.venv/bin/mcp-server-git"
      ]
    },
    "websearch": {
      "type": "local",
      "command": [
        "env",
        "USE_PROXY=true",
        "PROXY_URL=http://localhost:1234",
        "HTTP_PROXY=http://localhost:1234",
        "HTTPS_PROXY=http://localhost:1234",
        "MODE=stdio",
        "DEFAULT_SEARCH_ENGINE=duckduckgo",
        "ALLOWED_SEARCH_ENGINES=duckduckgo,bing,exa",
        "npx",
        "-y",
        "open-websearch@latest"
      ]
    }
  },
  // "model": "anthropic/claude-sonnet-4-6",
  // "model": "antigravity-gemini-3.1-pro",
  // "model": "google/antigravity-gemini-3-flash",
  // "model": "google/gemini-3-pro-preview",
  // "model":"github_copilot/claude-sonnet-4.5",
  "model": "openai/gpt-5.4",
  "small_model": "litellm/gpt-5-mini",
  "permission": {
    // Only deny non-standard tools
    "chrome_*": "deny",
    "context7_*": "deny",
    "filesystem_*": "deny",
    "git_*": "deny",
    "google_search": "deny",
    "pty_*": "deny",
    "websearch_*": "deny"
  },
  "plugin": [
    "@plannotator/opencode",
    "opencode-antigravity-auth@latest",
    //    "opencode-antigravity-quota@latest",
    "opencode-pty",
    //"file:///home/me/experimental/auto-agents/dist/plugin.js"
  ],
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "GitHub Copilot (GHE)",
      "options": {
        "baseURL": "http://localhost:4000/v1",
        "apiKey": "sk-1234",
      },
      "models": {
        "claude-fast": {
          "id": "anthropic/claude-haiku-4.5",
          "name": "Claude Haiku 4.5 (Proxy)",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 200000,
            "output": 200000,
          },
        },
        "claude-balanced": {
          "id": "anthropic/claude-sonnet-4.6",
          "name": "Claude Sonnet 4.6 (Proxy)",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 200000,
            "output": 200000,
          },
        },
        "claude-smart": {
          "id": "anthropic/claude-opus-4.6",
          "name": "Claude Opus 4.6 (Proxy)",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 200000,
            "output": 200000,
          },
        },
        "claude-haiku-4.5": {
          "id": "github_copilot/claude-haiku-4.5",
          "name": "Claude Haiku 4.5 (GHE)",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 128000,
            "output": 128000,
          },
        },
        "claude-sonnet-4.6": {
          "id": "github_copilot/claude-sonnet-4.6",
          "name": "Claude Sonnet 4.6 (GHE)",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 128000,
            "output": 128000,
          },
        },
        "claude-opus-4.6": {
          "id": "github_copilot/claude-opus-4.6",
          "name": "Claude Opus 4.6 (GHE)",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 128000,
            "output": 128000,
          },
        },
        "gpt-5-mini": {
          "id": "github_copilot/gpt-5-mini",
          "name": "GPT 5 Mini (GHE)",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 128000,
            "output": 128000,
          },
        },
        "gpt-5.3-codex": {
          "id": "github_copilot/gpt-5.3-codex",
          "name": "GPT 5.3 Codex (GHE)",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 128000,
            "output": 128000,
          },
        },
        //        "gpt-5.4": {
        //          "id": "github_copilot/gpt-5.4",
        //          "name": "GPT 5.4 (GHE)",
        //          "attachment": true,
        //          "reasoning": true,
        //          "temperature": true,
        //          "tool_call": true,
        //          "limit": {
        //            "context": 1000000,
        //            "output": 1000000
        //          }
        //        },
        "gemini-2.5-pro": {
          "id": "github_copilot/gemini-2.5-pro",
          "name": "Gemini 2.5 Pro (GHE)",
          "attachment": true,
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
          "limit": {
            "context": 1000000,
            "output": 1000000,
          },
        },
      },
    },
    "google": {
      "npm": "@ai-sdk/google",
      "models": {
        "antigravity-gemini-3-pro": {
          "name": "Gemini 3 Pro (Antigravity)",
          "limit": {
            "context": 1048576,
            "output": 65535,
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ],
          },
          "variants": {
            "low": {
              "thinkingLevel": "low",
            },
            "high": {
              "thinkingLevel": "high",
            },
          },
        },
        "antigravity-gemini-3.1-pro": {
          "name": "Gemini 3.1 Pro (Antigravity)",
          "limit": {
            "context": 1048576,
            "output": 65535,
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ],
          },
          "variants": {
            "low": {
              "thinkingLevel": "low",
            },
            "high": {
              "thinkingLevel": "high",
            },
          },
        },
        "antigravity-gemini-3-flash": {
          "name": "Gemini 3 Flash (Antigravity)",
          "limit": {
            "context": 1048576,
            "output": 65536,
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ],
          },
          "variants": {
            "minimal": {
              "thinkingLevel": "minimal",
            },
            "low": {
              "thinkingLevel": "low",
            },
            "medium": {
              "thinkingLevel": "medium",
            },
            "high": {
              "thinkingLevel": "high",
            },
          },
        },
        "antigravity-claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 (Antigravity)",
          "limit": {
            "context": 200000,
            "output": 64000,
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ],
          },
        },
        "antigravity-claude-opus-4-6-thinking": {
          "name": "Claude Opus 4.6 Thinking (Antigravity)",
          "limit": {
            "context": 200000,
            "output": 64000,
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ],
          },
          "variants": {
            "low": {
              "thinkingConfig": {
                "thinkingBudget": 8192,
              },
            },
            "max": {
              "thinkingConfig": {
                "thinkingBudget": 32768,
              },
            },
          },
        },
        "gemini-2.5-flash": {
          "name": "Gemini 2.5 Flash (Gemini CLI)",
          "limit": {
            "context": 1048576,
            "output": 65536,
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
