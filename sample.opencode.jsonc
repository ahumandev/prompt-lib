    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1",
      },
      "models": {
        "cogito": {
          "id": "cogito:8b",
          "name": "Cogito (Language)",
          "attachment": true,
          "limit": {
            "context": 16000,
            "output": 16000,
          },
          "reasoning": true,
          "temperature": true,
          "tool_call": true,
        },
        "qwen-2-5-coder": {
          "id": "qwen2.5-coder:latest",
          "name": "Qwen 2.5 (Coder)",
          "attachment": false,
          "limit": {
            "context": 16000,
            "output": 16000,
          },
          "reasoning": false,
          "temperature": true,
          "tool_call": false,
        },
        "qwen-3": {
          "id": "qwen3:14b",
          "name": "Qwen 3 (Tools)",
          "attachment": true,
          "limit": {
            "context": 12000,
